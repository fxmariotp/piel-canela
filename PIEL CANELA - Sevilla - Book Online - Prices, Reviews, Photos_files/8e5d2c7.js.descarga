m travel distance."},"title":"Travel Fee Policy"},"variant":{"label":{"free":"Free","starts_at":"Starts at {price}","varies":"Varies"}}},"business_details":{"membership":{"dialog":{"no_offers":{"confirm":"Got it","description":"It looks like there are no memberships available at the moment. Please contact the business directly to ask about their latest offers.","title":"Looking for a membership?"}}},"packages":{"components":{"tab":{"label":"Packages"}},"empty_state":{"description":"Save more with multi-visit packages. Speak with our team during your next visit for more details.","title":"No packages available yet"},"heading":{"title":"Choose a package"},"notice":{"in_store":{"description":"Speak with our team during your next visit to explore your options.","title":"Packages are exclusively available in-store."}},"package_details":{"button":{"buy":"Buy package","show_more":"Show more ({count})"},"disclaimer":{"non_personalized_cards":"Cards are not personalized and can be used by anyone with the card number until the balance is fully reached."},"summary":{"label":{"expiration_period":"Expiration period"}}}},"packages_card":{"detail":{"sessions":"Sessions: {session_count}"},"label":{"expiration_period":"Expiration period"}},"translation":{"loading":{"subtitle":"This usually takes a few seconds.","title":"Translating services to {language}..."},"option":{"english":"English","original":"{language} (Original)","spanish":"Spanish","translate_to":"Translate to {language}"}}},"home":{"book_self_care":{"title":"Book self-care in seconds"},"favorites":{"main":{"section":{"title":"Favorites and finds"}}}},"location_search":{"add_address":{"detail":{"save_help":"You can save the address to your profile for future appointments"},"textfield":{"apartment":{"title":"Apartment or suite number (optional)"},"city":{"title":"City"},"postcode":{"title":"Post code"},"street":{"title":"Street"}},"toggle":{"save":"Save address to your Profile?"}},"address_selection":{"subtitle":"Choose the place where you\'d like your mobile service to take place.","title":"Mobile service address"},"geolocation":{"button":{"enable":"Enable"},"detail":{"disabled":"Location access disabled","enabled":"Location enabled","error":"Unable to access location","not_supported":"Geolocation not supported by your browser"},"title":"Current location"},"search":{"button":{"add_new":"Add a new service address","use_profile":"Use your profile address"}}},"marketing":{"consent":{"button":{"see_full":"See full content of the marketing consent"},"text":{"description":"By clicking \'yes,\' you agree to receiving offers from {business}."}}},"packages":{"components":{"package_details":{"title":"Package details"}},"package_details":{"section":{"components":{"valid_for":{"title":"Valid for:"}}},"summary":{"components":{"label":{"amount":"Amount"}}}}},"packages_card":{"components":{"label":{"amount":"Amount"}}},"payments":{"blik":{"textfield":{"code":{"error":{"invalid":"BLIK code is too short"},"message":"You\'ll find your code in your banking app","placeholder":"BLIK code"}}},"cancellation_policy":{"booksy_gift_card":{"description":"They won’t apply for booking this appointment with gift cards.","title":"No deposit or cancellation fee applies"},"button":{"details":"View details and policy"},"cancellation_fee":{"description":"<b>Free cancellation before {time}:</b> Only pay {fee} if you cancel late or miss your booking."},"deposit":{"description":"<b>A deposit is required:</b> To secure this booking, you’ll pay a deposit of {deposit} today."},"title":"Cancellation policy"},"cancellation_policy_details":{"cancellation_fee":{"section":{"description":"If you cancel late or miss your appointment, you may be charged a cancellation fee. To avoid it, cancel or reschedule at least <b>{time} before your appointment time.</b><br><br>Your card is securely stored but you won\'t be charged at the time of booking. You would only be charged if the provider’s cancellation policy is not followed.","title":"How cancellation fees work"}},"deposits":{"section":{"description":"The deposit is a non-refundable payment required by the provider to secure your appointment. It is charged to your card at the time of booking. The amount will be deducted from your appointment payment.<br><br>By booking an appointment, you agree to this charge in accordance with the provider\'s terms.","title":"How deposits work"}},"policy":{"section":{"title":"Policy"}}},"card_form":{"button":{"submit":"Add card"},"description":"Add card to your Booksy account and get to know Mobile Payments — fast, convenient and secure.","terms":{"detail":"By saving the card you agree to","link":"Booksy Terms & Conditions"},"title":"Add your payment card","toast":{"success":"Card saved successfully"}},"cash_app":{"button":{"pay":"Pay with Cash App"},"refund":{"policy":"You will be redirected to Cash App to complete your payment securely, and by doing so you agree to the [Refund Policy](/)."}},"confirm":{"button":{"book_and_pay":"Book and pay {amountToPay}","pay":"Pay {amount}"}},"gift_card":{"add":{"heading":{"title":"Enter your gift card number"},"text":{"error_invalid":"Invalid gift card code"},"textfield":{"number":{"placeholder":"Gift card number"}}},"manage":{"button":{"add_another":"Add gift card","confirm":"Confirm"},"heading":{"title":"Your discounts"},"label":{"gift_card":"Booksy Gift Card"},"text":{"no_cards":"No gift cards available","select_alert":"Please select at least one gift card","valid_days":"Valid for {count} days | Valid for {count} day | Valid for {count} days"}},"tile":{"button":{"add":"Add now","manage":"Manage"},"label":{"added":"Booksy Gift Card total:"},"text":{"add_prompt":"Do you have a Booksy Gift Card?"}}},"methods":{"button":{"add_card":"Add payment card","select":"Select","show_more":"More options"},"description":"Select your preferred payment method","payment_method":{"section":{"title":"Payment method"}},"title":"Payment methods"},"platform_fee":{"detail":{"method_not_support