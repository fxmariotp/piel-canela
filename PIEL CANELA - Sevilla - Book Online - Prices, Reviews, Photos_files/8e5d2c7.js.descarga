sy recommended","recommend-short":"Recommended","staff":{"title":"Meet our team"}},"explore-similar-businesses":"Explore similar businesses","klarna-badge":"Klarna","not-available-for-booking":{"info":"Business Unavailable","small-text":"This business is no longer available for online booking."},"not-found":{"button":"Go to search","info":"This business is no longer available.","small-text":"Don\'t worry! There\'s lots of other great businesses to book with on Booksy."},"partials":{"amenities":{"title":"Amenities"},"booking-rules":{"title":"Booking Policies"},"booksy-pay-info-modal":{"cashback-terms":"Cashback Terms","content-booksy-pay":"Booksy Pay allows you to complete payment for your booking right in the app! It\'s fast, secure and you can pay up to 10 days before or 2 hours after your appointment.","content-cashback":"This offer applies to bookings of at least 50 zł and requires payment with a Visa or Mastercard in the Booksy app. Promotion is valid until 31.01.2026 or until the promotion budget is used up.","done":"Done","title-booksy-pay":"This business accepts Booksy Pay","title-cashback":"Get 20 zł cashback with Booksy Pay"},"business-contact-info":{"hidden-details":"Hidden details","login-to-show":"Log in or create an account on Booksy to contact this business","show":"Show"},"contractors":{"no-contractors-info":"There are no professionals at this venue yet."},"details":{"about-us":"About us","business-details":"Business details","contact":"Contact number","contact-and-hours":"Contact & Business hours","deposit-policy":"Payment & Cancellation Policy","hours":"Business hours","report":"Report","share-img-title":"Share inspiration","share-title":"Share Business","social-media":"Social Media","social-media-share":"Social Media & Share","staffers":"Staffers","suggest-changes":"Suggest changes","traveling-policy":"Travel Fee & Policy"},"facilities":{"animals":"Pets allowed","credit_cards":"Payment cards accepted","kids":"Children-friendly","loyalty":"Loyalty P